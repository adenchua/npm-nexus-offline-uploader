# =============================================================================
# npm-offline-uploader — Environment Configuration Template
#
# Copy this file to .env and fill in the values for your environment.
#   cp .env.template .env
#
# NEVER commit .env to version control. It is already listed in .gitignore.
# This template file is safe to commit — it contains no real credentials.
# =============================================================================

# Base URL of your Sonatype Nexus Repository Manager instance.
# Do not include a trailing slash.
# Example: http://nexus.internal:8081
NEXUS_URL=

# Name of the npm-hosted repository in Nexus to upload packages into.
# Example: npm-hosted
NEXUS_REPOSITORY=

# Nexus username with deploy privileges on the target repository.
# Use a dedicated service account rather than a personal admin account.
NEXUS_USERNAME=

# Password for the Nexus user above.
# Treat this value as a secret — do not share or log it.
NEXUS_PASSWORD=
